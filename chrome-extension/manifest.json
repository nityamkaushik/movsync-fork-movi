{
  "manifest_version": 3,
  "name": "Movi Player",
  "version": "0.3.3",
  "description": "A modern video player that handles formats and codecs your browser can't play natively — right in your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["contextMenus", "activeTab", "clipboardRead", "storage"],
  "optional_host_permissions": ["<all_urls>"],
  "cross_origin_embedder_policy": { "value": "require-corp" },
  "cross_origin_opener_policy": { "value": "same-origin" },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["marker.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["player.html", "player.js", "popup.js", "dist/*"],
      "matches": ["<all_urls>", "file:///*"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
